generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                String              @id @default(uuid())
  name              String
  slug              String              @unique
  email             String              @unique
  passwordHash      String
  document          String
  createdAt         DateTime            @default(now())
  customers         Customer[]
  meals             Meal[]
  discountRule      DiscountRule?
  admins            Admin[]
  subscription      Subscription?
  registrationLinks RegistrationLink[]
}

model Subscription {
  id               String             @id @default(uuid())
  tenantId         String             @unique
  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  plan             PlanType           @default(monthly)
  status           SubscriptionStatus @default(trial)
  trialEndsAt      DateTime
  currentPeriodEnd DateTime?
  gracePeriodEnd   DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

enum PlanType {
  monthly
  quarterly
  annual
}

enum SubscriptionStatus {
  trial
  active
  past_due
  blocked
}

model Admin {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model SuperAdmin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model RegistrationLink {
  id        String   @id @default(uuid())
  code      String   @unique
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  cpf       String
  phone     String?
  balance   Decimal  @default(0) @db.Decimal(10, 2)
  noShowCount Int @default(0)
  isBlocked Boolean @default(false)
  blockReason String?
  lastNoShowAt DateTime?
  createdAt DateTime @default(now())
  orders    Order[]
  transactions WalletTransaction[]

  @@unique([tenantId, cpf])
}

model WalletTransaction {
  id          String      @id @default(uuid())
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id])
  type        TransactionType
  amount      Decimal     @db.Decimal(10, 2)
  description String?
  createdAt   DateTime    @default(now())
}

enum TransactionType {
  CREDIT
  DEBIT
}

model Meal {
  id           String        @id @default(uuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  name         String
  description  String?
  basePrice    Decimal       @db.Decimal(10, 2)
  date         DateTime      @db.Date
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  optionGroups OptionGroup[]
  orderItems   OrderItem[]
}

model OptionGroup {
  id      String      @id @default(uuid())
  mealId  String
  meal    Meal        @relation(fields: [mealId], references: [id])
  name    String
  type    GroupType
  required Boolean   @default(false)
  options Option[]
}

enum GroupType {
  single
  multiple
}

model Option {
  id             String            @id @default(uuid())
  groupId        String
  group          OptionGroup       @relation(fields: [groupId], references: [id])
  name           String
  price          Decimal           @default(0) @db.Decimal(10, 2)
  orderItemOptions OrderItemOption[]
}

model Order {
  id          String      @id @default(uuid())
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id])
  totalAmount Decimal     @db.Decimal(10, 2)
  discount    Decimal     @default(0) @db.Decimal(10, 2)
  status      OrderStatus @default(PENDING)
  pickedUp    Boolean     @default(false)
  pickedUpAt  DateTime?
  createdAt   DateTime    @default(now())
  items       OrderItem[]
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PICKED_UP
  CANCELLED
}

model OrderItem {
  id        String            @id @default(uuid())
  orderId   String
  order     Order             @relation(fields: [orderId], references: [id])
  mealId    String
  meal      Meal              @relation(fields: [mealId], references: [id])
  quantity  Int               @default(1)
  unitPrice Decimal           @db.Decimal(10, 2)
  options   OrderItemOption[]
}

model OrderItemOption {
  id          String    @id @default(uuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  optionId    String
  option      Option    @relation(fields: [optionId], references: [id])
}

model DiscountRule {
  id            String   @id @default(uuid())
  tenantId      String   @unique
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  cutoffTime    String   // "HH:MM"
  discountValue Decimal  @db.Decimal(5, 2)
  maxNoShowsBeforeBlock Int @default(3)
  updatedAt     DateTime @updatedAt
}
